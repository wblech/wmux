#compdef wmux
# Zsh completion for wmux.
# Place this file in a directory listed in $fpath (e.g. /usr/local/share/zsh/site-functions/).

_wmux_sessions() {
    local -a sessions
    sessions=(${(f)"$(wmux list --quiet 2>/dev/null)"})
    _describe 'session' sessions
}

_wmux() {
    local -a subcommands
    subcommands=(
        'daemon:Start the daemon process'
        'create:Create a new session'
        'attach:Attach to a session'
        'detach:Detach from a session'
        'kill:Kill a session or sessions by prefix'
        'list:List sessions'
        'info:Show session info'
        'status:Show daemon status'
        'events:Subscribe to events'
        'exec:Send input to a session without attaching'
        'wait:Wait for a session condition'
        'record:Start or stop session recording'
        'history:Show session scrollback history'
    )

    _arguments -C \
        '--socket[Unix socket path]:path:_files' \
        '--token[Token file path]:path:_files' \
        '1:command:->command' \
        '*::arg:->args'

    case "$state" in
        command)
            _describe 'command' subcommands
            ;;
        args)
            case "${words[1]}" in
                attach|detach|info)
                    _wmux_sessions
                    ;;
                kill)
                    _arguments \
                        '--prefix[Kill all sessions with prefix]:prefix:' \
                        '*:session:_wmux_sessions'
                    ;;
                list)
                    _arguments \
                        '--prefix[Filter by prefix]:prefix:' \
                        '(-q --quiet)'{-q,--quiet}'[Output session IDs only]'
                    ;;
                create)
                    _arguments \
                        '--shell[Shell binary]:shell:_command_names' \
                        '--cwd[Working directory]:dir:_directories' \
                        '1:session-id:'
                    ;;
                exec)
                    _arguments \
                        '--sync[Send to multiple sessions]' \
                        '--prefix[Target sessions by prefix]:prefix:' \
                        '--no-newline[Do not append newline]' \
                        '*:session:_wmux_sessions'
                    ;;
                events)
                    _arguments \
                        '1:session:_wmux_sessions'
                    ;;
                wait)
                    _arguments \
                        '--timeout[Timeout in milliseconds]:ms:' \
                        '1:session:_wmux_sessions' \
                        '2:mode:(exit idle match)'
                    ;;
                record)
                    _arguments \
                        '1:action:(start stop)' \
                        '2:session:_wmux_sessions'
                    ;;
                history)
                    _arguments \
                        '--format[Output format]:format:(ansi text html)' \
                        '--lines[Number of lines]:lines:' \
                        '1:session:_wmux_sessions'
                    ;;
            esac
            ;;
    esac
}

_wmux "$@"
